# Runtime mode
NODE_ENV=development
PORT=5000

# Secrets bootstrap
# Production: use a secret manager and keep the direct secret values below empty.
# Supported values: env | aws-secrets-manager | vault
SECRETS_PROVIDER=env

# AWS Secrets Manager
# AWS_REGION=us-east-1
# AWS_SECRETS_MANAGER_SECRET_ID=nabd-ai-assistant/prod

# HashiCorp Vault
# VAULT_ADDR=https://vault.example.com
# VAULT_NAMESPACE=
# VAULT_KV_PATH=kv/data/nabd-ai-assistant/prod
# Prefer AppRole or workload identity over long-lived root tokens
# VAULT_ROLE_ID=
# VAULT_SECRET_ID=
# VAULT_TOKEN=

# Server-only secrets
AI_API_KEY=
NVIDIA_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
NEWS_API_KEY=
IPSTACK_API_KEY=
DATABASE_URL=
REDIS_URL=
DEBUG_API_TOKEN=
SUPABASE_SERVICE_ROLE_KEY=

# Public-by-design or non-secret runtime values
SUPABASE_PROJECT_ID=
SUPABASE_URL=
AI_ENDPOINT=https://integrate.api.nvidia.com/v1/chat/completions
AI_MODEL=meta/llama-3.1-70b-instruct
AI_REQUEST_TIMEOUT_MS=30000
UI_SCHEMA_PROVIDER=
UI_SCHEMA_TIMEOUT_MS=30000
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_ENDPOINT=https://api.openai.com/v1/chat/completions
GEMINI_MODEL=gemini-1.5-flash
GEMINI_API_ENDPOINT=
ENABLE_AI_DEBUG_ENDPOINTS=
NABD_SKILLS_DIR=
RAG_STORE_PATH=
ENABLE_PHONE_PROXY=
PHONE_PROXY_TIMEOUT_MS=120000

# Browser-exposed values must never contain secrets
VITE_PHONE_API_BASE=
VITE_PHONE_MODEL=tinyllama

# Supabase public client key (safe for browser use only if RLS is enforced)
SUPABASE_ANON_KEY=
